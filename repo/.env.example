# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=fitcommerce
POSTGRES_PASSWORD=fitcommerce_secret
POSTGRES_DB=fitcommerce

# ─── JWT ──────────────────────────────────────────────────────────────────────
# IMPORTANT: Replace both secrets with strong random values in production.
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# ─── Application ──────────────────────────────────────────────────────────────
ENV=development
PORT=8080

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL that the browser uses to reach the backend API.
# For local development with Docker Compose this is always http://localhost:8080.
VITE_API_URL=http://localhost:8080
